# ResearchPilot AI Environment Configuration Example
# Copy this file to .env and configure appropriate values for your deployment environment.

# Security & Authentication
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Gemini API Configuration
# Provide multiple API keys separated by commas for multi-key rotation
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash

# CORS Configuration
# Provide comma-separated origins or a JSON list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-app.vercel.app

# Server Port
PORT=8000
